# 生产环境配置
VITE_APP_TITLE=AI Chat
VITE_API_BASE_URL=https://yesbabeabc.com
VITE_APP_ENV=production
VITE_APP_PORT=5173
VITE_APP_OPEN_BROWSER=false

# API相关配置
VITE_API_TIMEOUT=30000
VITE_API_PREFIX=/api

# WebSocket相关配置 - 自动检测协议和域名
VITE_WS_BASE_URL=auto
VITE_WS_ASSETS_URL=https://yesbabeabc.com
VITE_WS_HEARTBEAT_INTERVAL=30000
VITE_WS_RECONNECT_INTERVAL=5000
VITE_WS_MAX_RECONNECT_ATTEMPTS=3

# 生产环境特定配置
VITE_APP_DEBUG=false
VITE_APP_MOCK=false